{
  "module": "module_3_rpa_boundary_check",
  "design_choice": "conditional_admissibility",
  "dimension_order": [
    "scenario_match",
    "instruction_support",
    "input_readiness",
    "rule_readiness",
    "platform_operability",
    "result_verifiability",
    "exception_containment"
  ],
  "required_module_2_facts": [
    "business_goal",
    "input_data",
    "operated_systems",
    "output_result",
    "completion_condition"
  ],
  "recommended_module_2_facts": [
    "trigger",
    "rule_clarity",
    "input_stability",
    "platform_operability",
    "result_verifiability"
  ],
  "global_rules": [
    "instruction_match_is_evidence_not_decision",
    "missing_required_module_2_facts_returns_not_ready",
    "module_3_must_not_repeat_module_2_boundary_clarification",
    "module_3_must_not_generate_process_breakdown",
    "module_3_questions_must_be_capability_critical",
    "captcha_is_conditional_capability_not_automatic_blocker"
  ],
  "memory_gate_policy": {
    "memory_module": "global_requirement_memory",
    "entry_transition": "module_2_to_module_3",
    "exit_transition": "module_3_to_module_4",
    "read_memory_before_decision": true,
    "write_boundary_decision_to_memory": true,
    "allow_partial_ready_with_carry_forward_gaps": true,
    "allowed_entry_gate_states": [
      "ready",
      "partial_ready"
    ],
    "blocked_gate_states": [
      "blocked"
    ],
    "flow_rule": "Start from confirmed memory facts and module 2 carry-forward gaps. Write the RPA boundary classification as a memory decision before deciding whether module 4 is ready, partial_ready, or blocked."
  },
  "classification_rules": {
    "suitable": {
      "required_dimension_statuses": {
        "scenario_match": ["pass"],
        "instruction_support": ["pass"],
        "rule_readiness": ["pass"],
        "platform_operability": ["pass"],
        "result_verifiability": ["pass"]
      },
      "allows_minor_conditionals": ["input_readiness", "exception_containment"]
    },
    "conditionally_suitable": {
      "default_for_real_customer_requirements": true,
      "requires_supported_core": true,
      "allows_prework_when_concrete": true,
      "containment_strategies": [
        "standardization",
        "field_mapping",
        "manual_review_queue",
        "login_stabilization",
        "captcha_instruction_matching",
        "paid_captcha_service_validation",
        "captcha_human_fallback",
        "result_logging",
        "api_or_data_export"
      ]
    },
    "not_ready": {
      "use_when": [
        "required_information_missing",
        "boundary_facts_not_confirmed",
        "input_rules_output_or_platform_access_cannot_be_judged_yet"
      ]
    },
    "not_suitable_for_direct_rpa": {
      "use_when": [
        "core_task_depends_on_open_ended_semantic_judgment_without_rules_or_review",
        "input_highly_unstable_and_cannot_be_standardized",
        "target_platform_cannot_be_operated_or_accessed_reliably",
        "verification_has_no_supported_instruction_no_human_fallback_and_requires_unattended_high_frequency_execution",
        "success_cannot_be_verified",
        "process_is_low_frequency_high_variability_and_heavy_manual_judgment"
      ]
    }
  },
  "captcha_assessment": {
    "principle": "captcha_is_conditional_capability_not_automatic_blocker",
    "must_check": [
      "captcha_type",
      "appearance_frequency",
      "adapted_instruction_or_candidate_capability",
      "paid_service_acceptance",
      "accuracy_acceptance",
      "human_fallback_allowed",
      "customer_authorization_and_platform_compliance"
    ],
    "conditional_when": [
      "captcha_type_is_common_or_has_candidate_instruction",
      "captcha_is_first_login_or_low_frequency",
      "customer_accepts_paid_service_accuracy_limit_or_human_fallback"
    ],
    "blocking_when": [
      "captcha_type_has_no_supported_instruction",
      "customer_disallows_paid_service_and_human_fallback",
      "captcha_appears_high_frequency",
      "customer_requires_fully_unattended_execution"
    ],
    "recommended_capability_notes": [
      "requires_captcha_type_confirmation",
      "requires_captcha_instruction_validation",
      "requires_paid_captcha_approval",
      "requires_human_verification_fallback"
    ]
  }
}
