{
  "module": "module_4_process_breakdown",
  "breakdown_depth": "business_process_cards_with_candidate_capabilities",
  "allowed_source_classifications": ["suitable", "conditionally_suitable"],
  "blocked_source_classifications": ["not_ready", "not_suitable_for_direct_rpa"],
  "default_card_count": {
    "minimum": 4,
    "maximum": 8
  },
  "required_card_fields": [
    "step_id",
    "step_name",
    "business_purpose",
    "input",
    "operation_summary",
    "output",
    "candidate_yingdao_capabilities",
    "depends_on",
    "prework_dependencies",
    "handoff_to_exception_design",
    "exception_design_notes"
  ],
  "required_result_fields": [
    "module",
    "status",
    "source_decision",
    "breakdown_depth",
    "process_cards",
    "assumptions",
    "validation_points",
    "cross_step_dependencies",
    "open_questions",
    "handoff_to_exception_design",
    "next_stage_recommendation"
  ],
  "default_card_pattern": [
    "trigger_and_preparation",
    "load_configuration_scope_or_input",
    "enter_or_connect_to_source_system",
    "read_query_download_or_collect_source_data",
    "normalize_match_filter_or_calculate_data",
    "enter_or_connect_to_target_system",
    "write_upload_notify_or_generate_output",
    "record_execution_result_and_handoff_items"
  ],
  "forbidden_behaviors": [
    "do_not_generate_exact_click_paths",
    "do_not_generate_selectors_or_wait_times",
    "do_not_design_exception_branches",
    "do_not_generate_instruction_parameters",
    "do_not_override_module_3_decision",
    "do_not_generate_html"
  ],
  "question_policy": {
    "ask_only_when_main_flow_cannot_be_coherent": false,
    "must_use_module_1_choice_format": true,
    "must_include_unknown_and_other_routes": true,
    "module_4_question_triggers": [
      "ask_when_implementation_path_is_ambiguous",
      "ask_when_repeated_object_or_loop_scope_is_missing",
      "ask_when_source_to_target_mapping_is_missing",
      "ask_when_branch_condition_changes_the_main_flow",
      "ask_when_candidate_instruction_family_is_unclear",
      "ask_when_online_table_write_position_is_unclear",
      "ask_when_login_or_captcha_step_affects_flow_sequence"
    ]
  },
  "handoff_policy": {
    "ready_next_module": "exception_design",
    "auto_transition_without_waiting_for_continue": true,
    "must_explain_transition_reason": true,
    "must_ask_next_module_questions_when_open_exception_topics_exist": true
  },
  "generation_requirements": [
    "preserve upstream assumptions that still constrain the main flow",
    "preserve validation points that must be confirmed before exception design or delivery",
    "keep required recommended and optional upstream classifications when they affect sequencing or risk"
  ]
}
